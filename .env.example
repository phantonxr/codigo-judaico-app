VITE_API_BASE_URL=https://erp-saas-codigojudaico.3oyj69.easypanel.host

# IMPORTANT
# - Do NOT put database, Stripe secret, SMTP password, or webhook secrets in Vite/React env vars.
# - Keep secrets only on the backend (.NET User Secrets, env vars, Docker secrets, etc.).
#
# Backend env vars expected by the API service:
# ConnectionStrings__Postgres=
# Stripe__SecretKey=
# Stripe__WebhookSecret=
# Stripe__ConnectedAccountId=
# Stripe__FrontendBaseUrl=
# Stripe__PlatformRetentionPercent=2
# Stripe__Monthly__PriceId=
# Stripe__Monthly__PlanName=Premium Mensal
# Stripe__Monthly__PromotionCouponId=
# Stripe__Annual__PriceId=
# Stripe__Annual__PlanName=Premium Anual
# Email__Enabled=true
# Email__Host=
# Email__Port=587
# Email__EnableSsl=true
# Email__Username=
# Email__Password=
# Email__FromEmail=
# Email__FromName=Codigo Judaico
